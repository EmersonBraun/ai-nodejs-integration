{
  "name": "nodejs-ai-ml-demo",
  "version": "1.0.0",
  "description": "REST API demonstrating AI and Machine Learning integration in Node.js",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write .",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "keywords": [
    "nodejs",
    "ai",
    "machine-learning",
    "nestjs",
    "gemini",
    "google-ai",
    "langchain",
    "typescript"
  ],
  "author": "Emerson Braun",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.1.3",
    "@langchain/community": "^1.1.1",
    "@langchain/core": "^1.1.8",
    "@langchain/google-genai": "^2.1.3",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.2.4",
    "@xenova/transformers": "^2.17.1",
    "chromadb": "^1.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "node-llama-cpp": "^3.14.5",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.4.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^10.0.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3"
  }
}
