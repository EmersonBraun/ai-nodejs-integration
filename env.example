# Google Gemini API Key (free with generous limits)
GEMINI_API_KEY=your_gemini_api_key_here

# Pinecone API Key (optional - if you want to use Pinecone instead of Chroma)
PINECONE_API_KEY=your_pinecone_api_key_here

# Redis URL (optional - for caching)
REDIS_URL=redis://localhost:6379

# Server port
PORT=3000

# Environment (development or production)
NODE_ENV=development

# Path to GGUF model (for local inference)
# Example: ./models/llama-7b-q4_0.gguf
LLAMA_MODEL_PATH=./models/llama-7b-q4_0.gguf
